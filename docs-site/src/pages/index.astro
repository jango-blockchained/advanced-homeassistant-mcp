---
/**
 * Docs site index. The real landing page; uses BaseLayout for the
 * sidebar + topnav shell. Per-page content is intentionally minimal
 * here — the focus is the navigation.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Card from "@/components/ui/card.astro";
import CardHeader from "@/components/ui/card-header.astro";
import CardTitle from "@/components/ui/card-title.astro";
import CardDescription from "@/components/ui/card-description.astro";
import CardContent from "@/components/ui/card-content.astro";
import Badge from "@/components/ui/badge.astro";
import Kbd from "@/components/ui/kbd.astro";
---

<BaseLayout
  title="Home Assistant MCP"
  description="Bridge your AI assistant and Home Assistant. 40+ tools, three transports, zero config."
>
  <div class="mb-8 flex flex-col gap-2">
    <h1>Home Assistant MCP</h1>
    <p class="text-muted-foreground text-lg">
      Bridge your AI assistant and your smart home. 40+ tools, three transports,
      zero config.
    </p>
    <div class="mt-2 flex flex-wrap items-center gap-2">
      <Badge>v1.0</Badge>
      <Badge variant="secondary">stable</Badge>
      <Badge variant="outline">draft docs</Badge>
    </div>
  </div>

  <div class="grid gap-4 sm:grid-cols-2">
    <Card>
      <CardHeader>
        <CardTitle>Getting Started</CardTitle>
        <CardDescription>Install, connect, and start talking to your house.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href="/getting-started/installation/">Installation</a></li>
          <li><a href="/getting-started/first-connection/">First Connection</a></li>
          <li><a href="/getting-started/connect-your-ai/">Connect Your AI</a></li>
        </ul>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>Architecture</CardTitle>
        <CardDescription>How the three entry points, the tool system, and the HA client fit together.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href="/architecture/overview/">Overview</a></li>
          <li><a href="/architecture/entry-points/">Entry Points</a></li>
          <li><a href="/architecture/tool-system/">Tool System</a></li>
        </ul>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>Tools Reference</CardTitle>
        <CardDescription>The 40+ tools your AI can call.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href="/tools/ha-tools/">HA Tools</a></li>
          <li><a href="/tools/generic-tools/">Generic Tools</a></li>
        </ul>
      </CardContent>
    </Card>

    <Card>
      <CardHeader>
        <CardTitle>Deployment</CardTitle>
        <CardDescription>Run the server over HTTP+WS, STDIO, or Smithery.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href="/deployment/http/">HTTP+WS</a></li>
          <li><a href="/deployment/stdio/">STDIO</a></li>
          <li><a href="/deployment/smithery/">Smithery</a></li>
        </ul>
      </CardContent>
    </Card>
  </div>

  <p class="text-muted-foreground mt-12 text-sm">
    Use the sidebar to browse all 19 pages, or press
    <Kbd>Cmd</Kbd> + <Kbd>K</Kbd> for search.
  </p>
</BaseLayout>
