---
/**
 * Docs site index. The real landing page; uses BaseLayout for the
 * sidebar + topnav shell. Per-page content is intentionally minimal
 * here — the focus is the navigation.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import Card from "@/components/ui/card.astro";
import CardHeader from "@/components/ui/card-header.astro";
import CardTitle from "@/components/ui/card-title.astro";
import CardDescription from "@/components/ui/card-description.astro";
import CardContent from "@/components/ui/card-content.astro";
import Badge from "@/components/ui/badge.astro";
import Kbd from "@/components/ui/kbd.astro";
import { link } from "@/lib/link";
---

<BaseLayout
  title="Home Assistant MCP"
  description="Bridge your AI assistant and Home Assistant. 40+ tools, three transports, zero config."
>
  <div class="mb-12 flex flex-col gap-4 py-8">
    <h1 class="text-4xl font-extrabold tracking-tight lg:text-5xl bg-gradient-to-br from-foreground to-foreground/70 bg-clip-text text-transparent">
      Home Assistant MCP
    </h1>
    <p class="text-muted-foreground text-xl max-w-[42rem] leading-relaxed">
      Bridge your AI assistant and your smart home. 40+ tools, three transports,
      zero config.
    </p>
    <div class="mt-4 flex flex-wrap items-center gap-3">
      <Badge class="px-3 py-1 text-sm">v1.0</Badge>
      <Badge variant="secondary" class="px-3 py-1 text-sm">stable</Badge>
      <Badge variant="outline" class="px-3 py-1 text-sm">draft docs</Badge>
    </div>
  </div>

  <div class="grid gap-6 sm:grid-cols-2">
    <Card class="transition-all hover:shadow-md hover:border-ring/50">
      <CardHeader>
        <CardTitle>Getting Started</CardTitle>
        <CardDescription>Install, connect, and start talking to your house.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href={link("/getting-started/installation/")}>Installation</a></li>
          <li><a href={link("/getting-started/first-connection/")}>First Connection</a></li>
          <li><a href={link("/getting-started/connect-your-ai/")}>Connect Your AI</a></li>
        </ul>
      </CardContent>
    </Card>

    <Card class="transition-all hover:shadow-md hover:border-ring/50">
      <CardHeader>
        <CardTitle>Architecture</CardTitle>
        <CardDescription>How the three entry points, the tool system, and the HA client fit together.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href={link("/architecture/overview/")}>Overview</a></li>
          <li><a href={link("/architecture/entry-points/")}>Entry Points</a></li>
          <li><a href={link("/architecture/tool-system/")}>Tool System</a></li>
        </ul>
      </CardContent>
    </Card>

    <Card class="transition-all hover:shadow-md hover:border-ring/50">
      <CardHeader>
        <CardTitle>Tools Reference</CardTitle>
        <CardDescription>The 40+ tools your AI can call.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href={link("/tools/ha-tools/")}>HA Tools</a></li>
          <li><a href={link("/tools/generic-tools/")}>Generic Tools</a></li>
        </ul>
      </CardContent>
    </Card>

    <Card class="transition-all hover:shadow-md hover:border-ring/50">
      <CardHeader>
        <CardTitle>Deployment</CardTitle>
        <CardDescription>Run the server over HTTP+WS, STDIO, or Smithery.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href={link("/deployment/http/")}>HTTP+WS</a></li>
          <li><a href={link("/deployment/stdio/")}>STDIO</a></li>
          <li><a href={link("/deployment/smithery/")}>Smithery</a></li>
        </ul>
      </CardContent>
    </Card>

    <Card class="transition-all hover:shadow-md hover:border-ring/50">
      <CardHeader>
        <CardTitle>Guides</CardTitle>
        <CardDescription>Advanced features and tutorials.</CardDescription>
      </CardHeader>
      <CardContent>
        <ul class="text-muted-foreground list-inside list-disc text-sm">
          <li><a href={link("/guides/speech-features/")}>Speech Features</a></li>
          <li><a href={link("/guides/adding-a-tool/")}>Adding a Tool</a></li>
          <li><a href={link("/guides/testing/")}>Testing</a></li>
        </ul>
      </CardContent>
    </Card>
  </div>

  <p class="text-muted-foreground mt-12 text-sm">
    Use the sidebar to browse all 20 pages, or press
    <Kbd>Cmd</Kbd> + <Kbd>K</Kbd> for search.
  </p>
</BaseLayout>
