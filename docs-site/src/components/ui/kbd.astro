---
/**
 * Kbd — styled keyboard key. Useful inline with prose for showing
 * shortcuts (e.g. <Kbd>Cmd</Kbd> + <Kbd>K</Kbd>).
 */
import { cn } from "@/lib/utils";
import type { HTMLAttributes } from "astro/types";
const { class: className, ...rest } = Astro.props as HTMLAttributes<"kbd">;
---
<kbd
  class={cn(
    "bg-muted text-muted-foreground pointer-events-none inline-flex h-5 select-none items-center gap-1 rounded border px-1.5 font-mono text-[10px] font-medium opacity-100",
    className,
  )}
  {...rest}
>
  <slot />
</kbd>
