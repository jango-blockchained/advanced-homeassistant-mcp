---
/**
 * TopNav — horizontal bar across the top of the content area.
 * Holds: a search trigger (Cmd+K), the theme toggle, and a link to
 * the GitHub repository. The search button is a static placeholder
 * for v1; the real <Command /> modal is mounted in subtask 13.
 */
import { REPO_URL } from "@/nav";
import { cn } from "@/lib/utils";
import ModeToggle from "@/components/ModeToggle.astro";
import Kbd from "@/components/ui/kbd.astro";

interface Props {
  currentSection?: string;
}
const { currentSection } = Astro.props;
---

<header
  class="bg-background sticky top-0 z-30 flex h-14 items-center gap-4 border-b px-6 backdrop-blur"
>
  <div class="flex-1">
    {currentSection && (
      <span class="text-muted-foreground text-sm">{currentSection}</span>
    )}
  </div>

  <button
    type="button"
    data-search-trigger
    onclick="document.dispatchEvent(new CustomEvent('open-search'))"
    class={cn(
      "border-input bg-background text-muted-foreground hover:bg-accent hover:text-accent-foreground inline-flex h-9 w-72 items-center gap-2 rounded-md border px-3 text-sm transition-colors",
    )}
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <span class="flex-1 text-left">Search docs...</span>
    <Kbd>Cmd</Kbd>
    <Kbd>K</Kbd>
  </button>

  <ModeToggle />

  <a
    href={REPO_URL}
    target="_blank"
    rel="noopener noreferrer"
    class="hover:bg-accent hover:text-accent-foreground inline-flex h-9 w-9 items-center justify-center rounded-md"
    aria-label="GitHub repository"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="currentColor"
    >
      <path
        d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.58.11.79-.25.79-.56 0-.28-.01-1.02-.02-2-3.2.69-3.87-1.54-3.87-1.54-.52-1.32-1.27-1.67-1.27-1.67-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.69 1.25 3.34.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.28-5.24-5.7 0-1.26.45-2.29 1.18-3.1-.12-.29-.51-1.47.11-3.07 0 0 .97-.31 3.18 1.18a11 11 0 0 1 5.79 0c2.21-1.49 3.18-1.18 3.18-1.18.62 1.6.23 2.78.11 3.07.74.81 1.18 1.84 1.18 3.1 0 4.43-2.7 5.4-5.27 5.69.41.36.78 1.06.78 2.14 0 1.55-.01 2.8-.01 3.18 0 .31.21.68.8.56C20.21 21.39 23.5 17.08 23.5 12 23.5 5.65 18.35.5 12 .5Z"
      ></path>
    </svg>
  </a>
</header>
