---
import { link } from "@/lib/link";
---

<footer class="mt-16 border-t border-border/40 py-8 text-sm text-muted-foreground">
  <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
    <div class="flex items-center gap-3">
      <a
        href="https://github.com/jango-blockchained/advanced-homeassistant-mcp"
        target="_blank"
        rel="noopener noreferrer"
        class="opacity-70 transition-opacity hover:opacity-100"
        aria-label="GitHub Repository"
      >
        <img
          src="https://shieldcn.dev/badge/GitHub-black?logo=github&size=sm"
          alt="GitHub"
          class="h-6"
        />
      </a>
      <a
        href="https://bun.sh"
        target="_blank"
        rel="noopener noreferrer"
        class="opacity-70 transition-opacity hover:opacity-100"
        aria-label="Bun Runtime"
      >
        <img
          src="https://shieldcn.dev/badge/Bun-black?logo=bun&size=sm"
          alt="Bun"
          class="h-6"
        />
      </a>
      <a
        href="https://www.typescriptlang.org/"
        target="_blank"
        rel="noopener noreferrer"
        class="opacity-70 transition-opacity hover:opacity-100"
        aria-label="TypeScript"
      >
        <img
          src="https://shieldcn.dev/badge/TypeScript-3178C6?logo=typescript&size=sm"
          alt="TypeScript"
          class="h-6"
        />
      </a>
    </div>
    <div class="text-center md:text-right">
      <p class="font-medium text-foreground/80">
        Not affiliated with, endorsed, or sponsored by Home Assistant.
      </p>
      <p class="mt-1 text-xs opacity-80">
        Home Assistant is a trademark of Nabu Casa, Inc.
      </p>
    </div>
  </div>
</footer>
